{
  "name": "Sale",
  "type": "object",
  "properties": {
    "customer_id": {
      "type": "string",
      "title": "Cliente"
    },
    "customer_name": {
      "type": "string",
      "title": "Nome do Cliente"
    },
    "items": {
      "type": "array",
      "title": "Itens",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "size": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "total": {
            "type": "number"
          }
        }
      }
    },
    "total_amount": {
      "type": "number",
      "title": "Valor Total"
    },
    "discount": {
      "type": "number",
      "title": "Desconto",
      "default": 0
    },
    "final_amount": {
      "type": "number",
      "title": "Valor Final"
    },
    "payment_method": {
      "type": "string",
      "title": "Forma de Pagamento",
      "enum": [
        "Dinheiro",
        "PIX",
        "Cart\u00e3o Cr\u00e9dito",
        "Cart\u00e3o D\u00e9bito",
        "Fiado",
        "Boleto"
      ]
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "Conclu\u00edda",
        "Pendente",
        "Cancelada"
      ],
      "default": "Conclu\u00edda"
    },
    "sale_date": {
      "type": "string",
      "title": "Data da Venda",
      "format": "date-time"
    },
    "notes": {
      "type": "string",
      "title": "Observa\u00e7\u00f5es"
    }
  },
  "required": [
    "customer_name",
    "items",
    "final_amount",
    "payment_method"
  ]
}